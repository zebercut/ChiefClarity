# Required: path to your cloud-synced data folder (Google Drive, OneDrive, Dropbox)
DATA_FOLDER_PATH=/path/to/your/cloud/synced/data/folder

# Local path for the database file (avoids cloud sync lock conflicts with SQLite).
# If not set, DB lives in DATA_FOLDER_PATH (not recommended for cloud-synced folders).
# A backup copy is automatically saved to DATA_FOLDER_PATH every 6 hours.
# DB_PATH=C:/Users/you/Documents/.lifeos

# API key is set automatically by the setup wizard on first launch.
# You can also set it manually here if preferred:
# ANTHROPIC_API_KEY=sk-ant-...

# Encryption at rest (optional). Set both if you enabled encryption in the app.
# The salt is shown in the app's config after setup — copy it here.
# ENCRYPTION_PASSPHRASE=your-passphrase-here
# ENCRYPTION_SALT=hex-encoded-16-byte-salt

# Google Calendar integration (FEAT018, optional).
# Create a Google Cloud project with Calendar API enabled, then set these:
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token
