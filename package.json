{
  "name": "chief-clarity",
  "version": "2.0.0",
  "description": "AI personal organizer — mobile-first, local-only",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "proxy": "node scripts/api-proxy.js",
    "dev": "concurrently -k --names proxy,expo,headless --prefix-colors yellow,cyan,magenta \"node scripts/api-proxy.js\" \"npx expo start --web\" \"node scripts/headless-runner.js\"",
    "dev:web": "concurrently -k \"node scripts/api-proxy.js\" \"npx expo start --web\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "headless": "node scripts/headless-runner.js",
    "migrate": "npx ts-node scripts/migrate-v1-data.ts",
    "typecheck": "tsc --noEmit",
    "build:web": "npx expo export --platform web",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "build:android": "npm run build:web && npx cap sync android",
    "build:ios": "npm run build:web && npx cap sync ios",
    "featmap": "node packages/featmap/featmap.js serve --dir=packages/feature-kit/features",
    "test": "node scripts/run-tests.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@libsql/client": "^0.17.2",
    "@react-native-async-storage/async-storage": "^1.23.0",
    "@xenova/transformers": "^2.17.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-document-picker": "~12.0.0",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.0",
    "expo-secure-store": "^55.0.11",
    "expo-status-bar": "~1.12.0",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "~3.31.0",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/react": "^18.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
